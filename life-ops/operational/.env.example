# PAV-OS Environment Variables
# Copy to .env and customize

# State directory for JSON persistence (default: ~/.time-tasker)
# TIME_TASKER_STATE_DIR=~/.time-tasker

# Dataset: production | golden | synthetic (default: production)
# TIME_TASKER_DATASET=production

# Set to 1 to disable input summary in CLI
# TIME_TASKER_NO_INPUT_SUMMARY=0

# Theme override: light | dark (default: auto-detect)
# PAV_THEME=dark
